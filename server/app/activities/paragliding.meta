{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/activities/layout,_N_T_/activities/[slug]/layout,_N_T_/activities/[slug]/page,_N_T_/activities/paragliding"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/activities/$d$slug/__PAGE__",
    "/activities/$d$slug",
    "/activities",
    "/_index",
    "/_head"
  ]
}